{
    "ADAPT_BATCH_NORM": false,
    "BASE_EXPERIMENTS_PATH": "exps",
    "BATCH_SIZE": 64,
    "DESCRIPTION": "same as v3 with dann",
    "DEVICE": "cpu",
    "ENABLE_PROFILER": false,
    "EXPERIMENT_NAME": "cesnet_multimodal_each_week_train_dann_v01/{}",
    "EXPERIMENT_PATH": "exps/cesnet_multimodal_each_week_train_dann_v01/{}",
    "EXPERIMENT_PLOTS_PATH": "exps/cesnet_multimodal_each_week_train_dann_v01/{}/plots",
    "EXPERIMENT_TENSORBOARD_PATH": "exps/cesnet_multimodal_each_week_train_dann_v01/{}/tensorboard",
    "EXPERIMENT_WEIGHTS_PATH": "exps/cesnet_multimodal_each_week_train_dann_v01/{}/weights",
    "LAMBDA_CORAL": 0.0,
    "LAMBDA_DANN": 1.0,
    "LAMBDA_MMD": 0,
    "LEARNING_RATE": 0.003,
    "MIN_FLOW_LENGTH": 100,
    "MMD_BANDWIDTHS": [
        0.1,
        1.0,
        10.0
    ],
    "MODEL_PARAMS": {
        "conv_type": "1d",
        "dropout_prob": 0.3,
        "use_batch_norm": true,
        "feature_extractor": {
            "conv_layers": [
                {
                    "out_channels": 16,
                    "kernel_size": 3,
                    "stride": 1,
                    "padding": 1
                },
                {
                    "out_channels": 32,
                    "kernel_size": 3,
                    "stride": 1,
                    "padding": 1
                },
                {
                    "out_channels": 64,
                    "kernel_size": 3,
                    "stride": 1,
                    "padding": 1
                }
            ],
            "pool_kernel_size": 2,
            "pool_stride": 2
        },
        "label_predictor": {
            "conv_layers": [
                {
                    "out_channels": 64,
                    "kernel_size": 3,
                    "stride": 1,
                    "padding": 1
                }
            ],
            "pool_kernel_size": 2,
            "pool_stride": 2,
            "fc_layers": [
                64
            ]
        },
        "domain_classifier": {
            "conv_layers": [
                {
                    "out_channels": 64,
                    "kernel_size": 3,
                    "stride": 1,
                    "padding": 1
                },
                {
                    "out_channels": 64,
                    "kernel_size": 3,
                    "stride": 1,
                    "padding": 1
                }
            ],
            "pool_kernel_size": 2,
            "pool_stride": 2,
            "fc_layers": [
                128,
                64
            ]
        },
        "lambda_rgl": 1.0,
        "lambda_grl_gamma": 10,
        "input_shape": 256
    },
    "NUM_EPOCHS": 50,
    "NUM_WORKERS": 4,
    "RESOLUTION": 256,
    "RUN_SANITY_CHECK": true,
    "SAVE_MODEL_CHECKPOINT": "exps/cesnet_multimodal_each_week_train_dann_v01/{}/weights/model_checkpoint_epoch_{epoch}.pth",
    "SAVE_PLOTS": true,
    "SEED": 42,
    "TRAIN_DATA_FRAC": 1.0,
    "TRAIN_PER_EPOCH_DATA_FRAC": 0.1,
    "USE_MULTIMODAL": true,
    "VAL_DATA_FRAC": 0.1,
    "WEIGHT_DECAY": 0.0001
}